<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>ChildSDKSplashImageURL</key>
    <string>https://picsum.photos/300/300.jpg</string>
    <key>NSFaceIDUsageDescription</key>
    <string>ログイン時の本人確認に使用します。</string>
    <!--
      Permits cleartext HTTP traffic to localhost so the "demo (Local Web)"
      scheme can point ChildSDK's WebView at the Vite dev server in web/.
    -->
